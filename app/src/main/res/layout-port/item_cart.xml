<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="6dp"
    android:paddingVertical="6dp">

    <!-- Left: Product info (no image in portrait to save space) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtCartProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#1F2937"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCartUnitPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Center: Quantity controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginHorizontal="4dp">

        <TextView
            android:id="@+id/btnMinus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/circle_green"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="-"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtQuantity"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="#1F2937"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPlus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/circle_green"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="+"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Right: Line total -->
    <TextView
        android:id="@+id/txtLineTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="#059669"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Remove button -->
    <TextView
        android:id="@+id/btnRemove"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="2dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="X"
        android:textColor="#DC2626"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- Hidden image view (keeps same view IDs so adapter code doesn't crash) -->
    <ImageView
        android:id="@+id/imgCartProduct"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:contentDescription="Product image" />
</LinearLayout>
