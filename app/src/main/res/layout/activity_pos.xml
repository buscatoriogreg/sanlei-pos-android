<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#065F46"
        app:title="Sanlei POS"
        app:titleTextColor="@android:color/white"
        app:menu="@menu/pos_menu"
        app:navigationIcon="@android:drawable/ic_menu_sort_by_size" />

    <!-- Content: Product grid + Cart side by side on tablets -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Left: Products -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Search bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                android:hint="Search product or scan barcode...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Letter filter -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/letterFilterLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Sync status bar -->
            <LinearLayout
                android:id="@+id/syncStatusBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FEF3C7"
                android:padding="6dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtSyncStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#92400E"
                    android:text="Offline mode - sales will sync when connected" />
            </LinearLayout>

            <!-- Products grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProducts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Right: Cart -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Cart header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#065F46"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Current Order"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCartCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 items"
                        android:textColor="#A7F3D0"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Cart items -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerCart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- SC/PWD discount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:background="#F9FAFB"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/chkScPwd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SC/PWD 20%"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/editScPwdId"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:hint="ID Number"
                        android:textSize="12sp"
                        android:visibility="gone"
                        android:layout_marginStart="8dp"
                        android:background="@android:drawable/editbox_background"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Totals -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="#F9FAFB">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal:" android:textSize="13sp" />
                        <TextView android:id="@+id/txtSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P0.00" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDiscount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SC/PWD Discount:" android:textSize="13sp" android:textColor="#DC2626" />
                        <TextView android:id="@+id/txtDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#DC2626" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL:" android:textSize="20sp" android:textStyle="bold" />
                        <TextView android:id="@+id/txtTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P0.00" android:textSize="20sp" android:textStyle="bold" android:textColor="#059669" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Payment method -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:gravity="center">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cash"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipGcash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GCash"
                            style="@style/Widget.Material3.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMaya"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maya"
                            style="@style/Widget.Material3.Chip.Filter" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>

                <!-- Amount paid + denomination buttons -->
                <LinearLayout
                    android:id="@+id/layoutCashPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="4dp">

                    <EditText
                        android:id="@+id/editAmountPaid"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="numberDecimal"
                        android:hint="Amount paid"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@android:drawable/editbox_background" />

                    <LinearLayout
                        android:id="@+id/layoutDenominations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Charge button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCharge"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_margin="8dp"
                    android:text="CHARGE P0.00"
                    android:textSize="16sp"
                    app:backgroundTint="#059669"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>
